{
  "name": "lark-hirono",
  "version": "0.1.0",
  "description": "Feishu (Lark) doc creation pipeline — markdown to styled Feishu documents with heading numbering, table conversion, and upload workflow",
  "packageManager": "pnpm@10.18.3",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charles1614/lark-hirono.git"
  },
  "homepage": "https://github.com/charles1614/lark-hirono#readme",
  "bugs": {
    "url": "https://github.com/charles1614/lark-hirono/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline.d.ts",
      "import": "./dist/pipeline.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "lark-hirono": "dist/bin/lark-hirono.js"
  },
  "scripts": {
    "build": "tsc",
    "pipeline": "tsx src/pipeline.ts",
    "preprocess": "tsx src/preprocess.ts",
    "verify": "tsx src/verify.ts",
    "lint": "eslint src/ bin/",
    "test": "bash tests/comprehensive-test.sh",
    "test:upload": "bash tests/upload-test.sh",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "feishu",
    "lark",
    "markdown",
    "document",
    "pipeline",
    "lark-table"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
